# Rasadhi Platform Frontend — Environment Configuration
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control

# Backend API origin. Leave unset for local development — the Vite dev
# server proxies /api/* to localhost:8000.
# In production, set to the deployed backend, e.g.
# VITE_API_URL=https://rasadhi-api.up.railway.app
# VITE_API_URL=
